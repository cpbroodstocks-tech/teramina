{
  "include": ["src"],
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,

    "ignoreDeprecations": "6.0",
    "baseUrl": "src",
    "paths": {
      "containers/*": ["features/*"],
      "widgets/*": ["features/dashboard/*"]
    }
  }
}
