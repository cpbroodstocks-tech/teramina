{
  "name": "Teramina",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "serve": "vite preview --port 5173",
    "deploy": "vite build && vite preview",
    "lint": "eslint -c .eslintrc.js --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix",
    "lint:staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "gen:types": "npx openapi-typescript http://localhost:8000/api/docs/openapi.json -o src/types/api.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
