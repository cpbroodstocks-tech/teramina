    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^14.1.0",
    "react-icons": "^4.6.0",
    "react-markdown": "9",
    "react-router-dom": "^7.14.2",
    "react-svg": "^15.1.20",
    "rehype-raw": "6",
    "tss-react": "^4.9.20",
    "universal-cookie": "^4.0.4",
