    "@mui/material": "^9.0.0",
    "@mui/system": "^9.0.0",
    "@mui/x-data-grid": "^9.0.4",
    "@mui/x-date-pickers": "^9.0.4",
    "@tanstack/react-query": "^5.99.0",
