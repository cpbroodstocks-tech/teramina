# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=
MONGOATLAS_USER=
MONGOATLAS_PASSWORD=
MONGOATLAS_HOST=
MONGOATLAS_DATABASE=

# JWT
JWT_SECRET_KEY=your-jwt-secret-here

# Firebase Admin
# Prefer FIREBASE_CREDENTIALS_JSON in hosted environments; use FIREBASE_CREDENTIALS_PATH for local files.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=

# Google Cloud Storage
# Prefer GOOGLE_APPLICATION_CREDENTIALS_JSON in hosted environments; use GOOGLE_APPLICATION_CREDENTIALS for local files.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GS_BUCKET_NAME=
GS_PROJECT_ID=
GS_VDB_BUCKET_NAME=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF — comma-separated trusted origins for POST/PUT/DELETE requests
CSRF_TRUSTED_ORIGINS=

# AI / Vector DB
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
open_ai_key=
TERAMINA_LLM_API=
TERAMINA_API_KEY=
SUMMARY_MODEL=claude-sonnet-4-6
PINECONE_API_KEY=
PINECONE_INDEX=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1
CELERY_BEAT_SCHEDULER=celery.beat:PersistentScheduler

# Monitoring — leave blank to disable Sentry
SENTRY_DSN=

# Request size limits (MB, default 10)
DATA_UPLOAD_MAX_MB=10
FILE_UPLOAD_MAX_MB=10
