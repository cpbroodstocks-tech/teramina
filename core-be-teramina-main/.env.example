# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGOATLAS_USER=
MONGOATLAS_PASSWORD=
MONGOATLAS_HOST=
MONGOATLAS_DATABASE=

# JWT
JWT_SECRET_KEY=your-jwt-secret-here

# Firebase
# Path to Firebase service account JSON (local dev) or leave blank to use ADC
GOOGLE_APPLICATION_CREDENTIALS=

# Google Cloud Storage
GS_BUCKET_NAME=
GS_PROJECT_ID=
GS_VDB_BUCKET_NAME=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF — comma-separated trusted origins for POST/PUT/DELETE requests
CSRF_TRUSTED_ORIGINS=

# AI / Vector DB
ANTHROPIC_API_KEY=
open_ai_key=
PINECONE_API_KEY=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Monitoring — leave blank to disable Sentry
SENTRY_DSN=

# Request size limits (MB, default 10)
DATA_UPLOAD_MAX_MB=10
FILE_UPLOAD_MAX_MB=10
